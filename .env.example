# JWT Configuration
JWT_SECRET=gymmate_jwt_secret_key_change_me
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Active billing provider (STRIPE or PAYSTACK)
PAYMENTS_PROVIDER=PAYSTACK

# Stripe Configuration
STRIPE_API_KEY=sk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your_connect_webhook_secret_here
STRIPE_APPLICATION_FEE_PERCENT=1.0

# Paystack Configuration
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
PAYSTACK_WEBHOOK_SECRET=paystack_webhook_secret_here
PAYSTACK_BASE_URL=https://api.paystack.co

# Frontend URL (for Stripe Connect redirects)
FRONTEND_URL=http://localhost:3000

# Database Configuration
PG_URI=jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
DB_DRIVER=org.h2.Driver
PG_USER=sa
PG_PASSWORD=
DB_DIALECT=org.hibernate.dialect.H2Dialect

# Use PostgreSQL in production

# Application Configuration
APP_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Security Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200
CORS_ALLOW_CREDENTIALS=true

# Logging Configuration
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_GYMMATE=DEBUG

# Additional Settings (for production)
# FLYWAY_ENABLED=true
# JPA_DDL_AUTO=validate
# SHOW_SQL=false

# Optional: switch back to Stripe
# PAYMENTS_PROVIDER=STRIPE

